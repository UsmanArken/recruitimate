# Database
DATABASE_URL=postgresql+asyncpg://recruitimate:recruitimate@localhost:5432/recruitimate

# Auth
AUTH_SECRET=change-me-use-openssl-rand-base64-32
AUTH_URL=http://localhost:8000

# LLM
LLM_PROVIDER=auto  # auto | openai | anthropic | google
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=gemini-1.5-flash
GOOGLE_AUDIO_MODEL=gemini-2.0-flash

# Transcription
TRANSCRIPTION_PROVIDER=none  # none | openai

# Storage
UPLOAD_DIR=./uploads

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# Platform admin
SUPER_ADMIN_EMAIL=admin@recruitimate.app
SUPER_ADMIN_PASSWORD=ChangeMeInProduction!12

# Environment
APP_ENV=development  # development | production | test

# Deepgram (live transcription)
DEEPGRAM_API_KEY=

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 (audio storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=recruitimate-audio
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Frontend URL (used for building candidate join links)
APP_URL=http://localhost:3000
