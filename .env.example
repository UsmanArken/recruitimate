# Database
DATABASE_URL="postgresql://recruitimate:recruitimate@localhost:5432/recruitimate?schema=public"

# LLM provider for talent / interview / decision / LinkedIn intelligence
# LLM_PROVIDER=auto   # auto | openai | anthropic | google (auto picks first configured key)
LLM_PROVIDER="auto"

# OpenAI
OPENAI_API_KEY="sk-..."
# OPENAI_CHAT_MODEL="gpt-4o-mini"

# Anthropic (optional)
# ANTHROPIC_API_KEY="..."
# ANTHROPIC_CHAT_MODEL="claude-3-5-haiku-latest"

# Google Gemini — GOOGLE_API_KEY, GEMINI_API_KEY, or GOOGLE_GENERATIVE_AI_API_KEY
# GOOGLE_API_KEY="AIza..."
# GOOGLE_CHAT_MODEL="gemini-1.5-flash"

# Whisper transcription (OpenAI only today)
# TRANSCRIPTION_PROVIDER=openai

# Local interview recording storage (default: ./uploads)
# STORAGE_PROVIDER=local
# UPLOAD_DIR="./uploads"

# S3-compatible media storage (MinIO, AWS S3, etc.)
# STORAGE_PROVIDER=s3
# S3_BUCKET="recruitimate-media"
# S3_REGION="us-east-1"
# S3_ENDPOINT="http://localhost:9000"
# S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID="minio"
# AWS_SECRET_ACCESS_KEY="minio123"
# S3_PREFIX="recruitimate"

# Background job worker poll interval (ms) when running npm run worker:jobs
# JOB_WORKER_INTERVAL_MS=3000

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Platform super admin (SaaS operator — not a customer org owner)
# Seed/bootstrap: npm run db:seed or npm run db:bootstrap-admin
# Production: set SUPER_ADMIN_EMAIL; that user is promoted on first login (never via /signup)
SUPER_ADMIN_EMAIL="admin@recruitimate.local"
SUPER_ADMIN_PASSWORD="ChangeMeInProduction!12"

# QA (optional — API smoke against running dev server)
# QA_BASE_URL="http://localhost:3000"

# Email notifications (P2-025) — log records to DB + console; smtp sends via nodemailer
# EMAIL_PROVIDER=log
# EMAIL_FROM="notifications@recruitimate.local"
# NOTIFICATIONS_ENABLED=true
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# Labor market / passive candidate signals (P3-007)
# LABOR_MARKET_PROVIDER=mock
# LABOR_MARKET_API_URL=https://api.example.com/labor-market
# LABOR_MARKET_API_KEY=
# LABOR_MARKET_TIMEOUT_MS=8000
