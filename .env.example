# Database
DATABASE_URL="postgresql://recruitimate:recruitimate@localhost:5432/recruitimate?schema=public"

# OpenAI (resume parsing, interview analysis, transcription)
OPENAI_API_KEY="sk-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Platform super admin (SaaS operator — not a customer org owner)
# Seed/bootstrap: npm run db:seed or npm run db:bootstrap-admin
# Production: set SUPER_ADMIN_EMAIL; that user is promoted on first login (never via /signup)
SUPER_ADMIN_EMAIL="admin@recruitimate.local"
SUPER_ADMIN_PASSWORD="ChangeMeInProduction!12"
