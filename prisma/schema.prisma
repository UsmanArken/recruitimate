generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth / Auth.js) ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  /// Platform operator (SaaS super admin). Never set via public signup.
  isPlatformAdmin Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMember[]
  invitesSent   Invite[]  @relation("InvitesSent")
  jobAssignments JobAssignment[]
  jobsManaged   Job[]     @relation("JobHiringManager")
  candidateNotes Note[]    @relation("NoteAuthor")
  outreachCampaigns OutreachCampaign[] @relation("OutreachCampaignCreator")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organization & RBAC (database rule engine) ─────────────────────────────

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  members   OrganizationMember[]
  invites   Invite[]
  jobs            Job[]
  candidates      Candidate[]
  jobApplications JobApplication[]
  talentPools     TalentPool[]
  outreachTemplates OutreachTemplate[]
  outreachCampaigns OutreachCampaign[]
  assessmentTasks   AssessmentTask[]
  backgroundJobs    BackgroundJob[]
  emailNotifications EmailNotification[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  scope       RoleScope        @default(ORGANIZATION)
  permissions RolePermission[]
  members     OrganizationMember[]
  invites     Invite[]
  createdAt   DateTime         @default(now())
}

enum RoleScope {
  ORGANIZATION
  JOB
  PLATFORM
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  resource    String
  action      String
  description String?
  roleLinks   RolePermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invite {
  id             String       @id @default(cuid())
  email          String
  token          String       @unique
  organizationId String
  roleId         String
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])
  invitedBy      User         @relation("InvitesSent", fields: [invitedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([email, organizationId])
}

/// Job-level access (e.g. interviewer on a specific requisition)
model JobAssignment {
  id             String             @id @default(cuid())
  jobId          String
  userId         String
  assignmentRole JobAssignmentRole
  job            Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@unique([jobId, userId, assignmentRole])
  @@index([userId])
}

enum JobAssignmentRole {
  HIRING_MANAGER
  INTERVIEWER
}

// ─── Hiring domain ───────────────────────────────────────────────────────────

enum PipelineStage {
  NEW
  TALENT_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  DECISION
  HIRED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  RECORDED
  TRANSCRIBED
  ANALYZED
}

model Job {
  id               String          @id @default(cuid())
  organizationId   String
  title            String
  description      String          @db.Text
  requirements     String?         @db.Text
  hiringManagerId  String?
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringManager    User?           @relation("JobHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)
  assignments   JobAssignment[]
  applications  JobApplication[]
  outreachCampaigns OutreachCampaign[]
  assessmentTasks   AssessmentTask[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([organizationId])
  @@index([hiringManagerId])
}

enum CandidateSource {
  MANUAL
  RESUME
  LINKEDIN
  BULK
  EXTERNAL
}

model Candidate {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  email          String?
  linkedInUrl    String?
  linkedInText   String?          @db.Text
  githubUrl      String?
  portfolioUrl   String?
  resumeText     String?          @db.Text
  resumeFilePath String?
  /// P2-009 how this profile entered the talent corpus
  source             CandidateSource @default(MANUAL)
  /// P2-009 denormalized text for discovery search (no raw files)
  searchDocument     String?         @db.Text
  /// P2-009 extracted skill keywords for ranking
  searchSkills       Json?
  discoveryIndexedAt DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications   JobApplication[]
  notes          Note[]
  poolMemberships TalentPoolMember[]
  outreachMessages OutreachMessage[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
  @@index([email])
}

/// P2-009 org-scoped talent pool for multi-source discovery
model TalentPool {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TalentPoolMember[]
  outreachCampaigns OutreachCampaign[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TalentPoolMember {
  id          String     @id @default(cuid())
  poolId      String
  candidateId String
  pool        TalentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  addedAt     DateTime   @default(now())

  @@unique([poolId, candidateId])
  @@index([candidateId])
}

/// One applicant's journey on a specific open position (hiring campaign).
model JobApplication {
  id             String          @id @default(cuid())
  organizationId String
  candidateId    String
  jobId          String
  stage          PipelineStage   @default(NEW)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  talentProfile  TalentProfile?
  interviews     Interview[]
  decision       Decision?
  assessmentSubmissions AssessmentSubmission[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([candidateId, jobId])
  @@index([organizationId])
  @@index([jobId])
  @@index([candidateId])
  @@index([stage])
}

model TalentProfile {
  id              String         @id @default(cuid())
  applicationId   String         @unique
  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  skills          Json      @default("[]")
  experienceYears Float?
  roleFitScore    Float?
  strengths       Json      @default("[]")
  gaps            Json      @default("[]")
  hiddenSignals   Json      @default("[]")
  explanation     String?   @db.Text
  rawAnalysis     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Interview {
  id              String             @id @default(cuid())
  applicationId   String
  application     JobApplication     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title           String
  status          InterviewStatus    @default(SCHEDULED)
  scheduledAt     DateTime?
  durationMinutes Int?               @default(60)
  meetingUrl      String?
  recordingPath   String?
  transcript      String?            @db.Text
  /// P2-007 pause / tone-shift signals from recording
  audioSignals    Json?
  /// P2-008 explicit opt-in timestamp for video behavioral analysis
  videoMetricsConsentAt DateTime?
  /// P2-008 engagement / attention metrics (aggregated — no raw frames)
  videoBehavioralMetrics Json?
  analysis        InterviewAnalysis?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([applicationId])
}

model InterviewAnalysis {
  id                String    @id @default(cuid())
  interviewId       String    @unique
  interview         Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  hesitationScore   Float?
  confidenceScore   Float?
  clarityScore      Float?
  consistencyScore  Float?
  engagementScore   Float?
  cognitiveSignals  Json      @default("[]")
  behavioralMetrics Json      @default("[]")
  riskFlags         Json      @default("[]")
  explanation       String?   @db.Text
  /// P2-006 interviewer quality: coverage, probing, bias advisory scores
  interviewerQuality Json?
  rawAnalysis       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Decision {
  id                String         @id @default(cuid())
  applicationId     String         @unique
  application       JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  hireConfidence    Float?
  recommendation    String?
  riskFactors       Json      @default("[]")
  comparisonNotes   String?   @db.Text
  explanation       String?   @db.Text
  signalBreakdown   Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Note {
  id          String    @id @default(cuid())
  candidateId String
  authorId    String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author      User?     @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  content     String    @db.Text
  tags        Json      @default("[]")
  createdAt   DateTime  @default(now())

  @@index([candidateId])
  @@index([authorId])
}

// ─── P2-012 Outreach Engine ──────────────────────────────────────────────────

enum OutreachCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum OutreachMessageStatus {
  DRAFT
  GENERATED
  SCHEDULED
  SENT
  DELIVERED
  OPENED
  REPLIED
  BOUNCED
  FAILED
}

enum OutreachEventType {
  SENT
  DELIVERED
  OPENED
  REPLIED
  BOUNCED
  FAILED
}

model OutreachTemplate {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  subject        String
  bodyMarkdown   String             @db.Text
  variables      Json               @default("[]")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      OutreachCampaign[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model OutreachCampaign {
  id              String                 @id @default(cuid())
  organizationId  String
  name            String
  status          OutreachCampaignStatus @default(DRAFT)
  jobId           String?
  poolId          String?
  templateId      String?
  subjectOverride String?
  createdById     String?
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job             Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  talentPool      TalentPool?        @relation(fields: [poolId], references: [id], onDelete: SetNull)
  template        OutreachTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy       User?              @relation("OutreachCampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  messages        OutreachMessage[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([organizationId])
  @@index([jobId])
  @@index([status])
}

model OutreachMessage {
  id              String                @id @default(cuid())
  organizationId  String
  campaignId      String
  candidateId     String
  status          OutreachMessageStatus @default(DRAFT)
  subject         String
  bodyText        String?               @db.Text
  bodyHtml        String?               @db.Text
  personalizedAt  DateTime?
  personalization Json?
  sentAt          DateTime?
  openedAt        DateTime?
  openCount       Int                   @default(0)
  repliedAt       DateTime?
  replySnippet    String?               @db.Text
  externalId      String?
  errorMessage    String?
  campaign        OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  candidate       Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  events          OutreachEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([campaignId, candidateId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([status])
}

model OutreachEvent {
  id        String            @id @default(cuid())
  messageId String
  type      OutreachEventType
  payload   Json?
  message   OutreachMessage   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@index([messageId])
  @@index([type])
}

// ─── P2-015 Assessment Engine ───────────────────────────────────────────────

enum AssessmentTaskType {
  CODE
  PRODUCT
  OPS
  SCENARIO
}

enum AssessmentSubmissionStatus {
  DRAFT
  SUBMITTED
  EVALUATED
}

model AssessmentTask {
  id               String             @id @default(cuid())
  organizationId   String
  jobId            String
  title            String
  prompt           String             @db.Text
  taskType         AssessmentTaskType
  difficulty       String             @default("medium")
  rubric           Json               @default("[]")
  skillsTested     Json               @default("[]")
  deliverables     Json               @default("[]")
  estimatedMinutes Int?               @default(60)
  rawGeneration    Json?
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job              Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions      AssessmentSubmission[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId])
  @@index([jobId])
}

model AssessmentSubmission {
  id             String                     @id @default(cuid())
  organizationId String
  applicationId  String
  taskId         String
  status         AssessmentSubmissionStatus @default(DRAFT)
  responseText   String?                    @db.Text
  responseUrl    String?
  submittedAt    DateTime?
  overallScore   Float?
  evaluation     Json?
  evaluatedAt    DateTime?
  application    JobApplication             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  task           AssessmentTask             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([applicationId, taskId])
  @@index([organizationId])
  @@index([applicationId])
  @@index([taskId])
}

enum BackgroundJobType {
  TRANSCRIBE_INTERVIEW
  ANALYZE_INTERVIEW
}

enum BackgroundJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model BackgroundJob {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           BackgroundJobType
  status         BackgroundJobStatus @default(QUEUED)
  payload        Json
  result         Json?
  error          String?             @db.Text
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  runAfter       DateTime            @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, runAfter])
  @@index([organizationId, createdAt])
}

enum EmailNotificationType {
  STAGE_CHANGE
  INTERVIEW_ANALYZED
}

enum EmailNotificationStatus {
  QUEUED
  SENT
  SKIPPED
  FAILED
}

model EmailNotification {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           EmailNotificationType
  status         EmailNotificationStatus @default(QUEUED)
  recipientEmail String
  subject        String
  bodyText       String                  @db.Text
  payload        Json?
  error          String?                 @db.Text
  sentAt         DateTime?
  createdAt      DateTime                @default(now())

  @@index([organizationId, createdAt])
  @@index([type, createdAt])
}
